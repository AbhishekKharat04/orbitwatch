# OpenAI Responses API: enables real AI/LLM operator briefings.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Auth/session signing.
APP_SECRET=replace-with-a-long-random-secret

# Upstash Redis REST: enables persistent user/watchlist database storage.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend: enables login-code email and alert delivery.
RESEND_API_KEY=
ALERT_FROM_EMAIL=OrbitWatch <onboarding@resend.dev>

# Legacy optional placeholder.
GROQ_API_KEY=
